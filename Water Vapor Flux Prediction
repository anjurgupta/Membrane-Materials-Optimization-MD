# ============================================================================
# STEP 1: DEFINE ANTOINE EQUATION FOR VAPOR PRESSURE
# ============================================================================

def calculate_vapor_pressure_antoine(temperature_celsius, substance='water'):
    """
    Calculate vapor pressure using Antoine equation
    
    Parameters:
    -----------
    temperature_celsius : float
        Temperature in °C
    substance : str
        Substance name ('water' by default)
    
    Returns:
    --------
    float : Vapor pressure in Pascal (Pa)
    
    Antoine Equation: log₁₀(P) = A - B/(C + T)
    Where P is vapor pressure in mmHg, T is temperature in °C
    1 mmHg = 133.322 Pa
    """
    
    if substance.lower() == 'water':
        # Water Antoine coefficients (valid 0-100°C range)
        A = 8.07131
        B = 1730.63
        C = 233.426
    else:
        raise ValueError("Currently only 'water' is supported")
    
    # Calculate log10 of vapor pressure in mmHg
    log_P_mmHg = A - B / (C + temperature_celsius)
    
    # Convert from mmHg to Pa
    P_Pa = (10 ** log_P_mmHg) * 133.322
    
    return P_Pa

# ============================================================================
# STEP 2: DEFINE DUSTY-GAS MODEL FOR FLUX PREDICTION
# ============================================================================

def predict_vapor_flux_dusty_gas(WVTR, porosity=0.70, tortuosity=2.0, 
                                  thickness_um=100, T_hot=70, T_cold=20):
    """
    Predict water vapor flux using dusty-gas model
    
    Theory:
    -------
    The dusty-gas model combines Knudsen diffusion (molecule-wall collisions)
    and molecular diffusion (molecule-molecule collisions):
    
    J = (WVTR × ε) / (τ × δ) × ΔP_vapor
    
    Where:
    - J : water vapor flux (kg·m⁻²·h⁻¹)
    - WVTR : water vapor transmission rate (g·mm·m⁻²·day⁻¹)
    - ε : membrane porosity (dimensionless, 0-1)
    - τ : tortuosity factor (dimensionless, typically 1.5-3.0)
    - δ : membrane thickness (m)
    - ΔP_vapor : vapor pressure driving force (Pa)
    
    Parameters:
    -----------
    WVTR : float
        Water vapor transmission rate from GRANTA (g·mm·m⁻²·day⁻¹)
    porosity : float
        Assumed membrane porosity (default 0.70 = 70%)
    tortuosity : float
        Tortuosity factor (default 2.0, typical for non-woven structures)
    thickness_um : float
        Assumed membrane thickness in micrometers (default 100 μm)
    T_hot : float
        Hot feed temperature (°C, default 70°C)
    T_cold : float
        Cold permeate temperature (°C, default 20°C)
    
    Returns:
    --------
    dict : Dictionary containing predicted flux and intermediate calculations
    """
    
    # Convert thickness from micrometers to meters
    thickness_m = thickness_um / 1e6
    
    # Calculate vapor pressures at operating temperatures using Antoine equation
    P_hot_Pa = calculate_vapor_pressure_antoine(T_hot, 'water')
    P_cold_Pa = calculate_vapor_pressure_antoine(T_cold, 'water')
    
    # Calculate vapor pressure driving force
    delta_P_Pa = P_hot_Pa - P_cold_Pa
    
    # Convert WVTR from g·mm·m⁻²·day⁻¹ to kg·m⁻²·h⁻¹
    # WVTR units: g·mm·m⁻²·day⁻¹
    # Convert: (g/1000 kg) × (1 mm = 1/1000 m) × (1 day = 1/24 h)
    # WVTR_SI = WVTR × (1/1000) × (1/1000) × (1/24) = WVTR × 4.167e-8
    WVTR_SI_units = WVTR / 1000 / 1000 / 24  # kg·m⁻²·h⁻¹ per unit WVTR value
    
    # Calculate predicted flux using dusty-gas model
    # J = (WVTR × ε) / (τ × δ) × ΔP_vapor
    flux_component = (WVTR * porosity) / (tortuosity * thickness_m)
    J_predicted = flux_component * delta_P_Pa * 1e-6  # Scale factor for unit conversion
    
    # Alternative direct calculation with proper unit conversion
    J_predicted_direct = (WVTR_SI_units * porosity / (tortuosity * thickness_m)) * delta_P_Pa
    
    return {
        'WVTR': WVTR,
        'Porosity': porosity,
        'Tortuosity': tortuosity,
        'Thickness_um': thickness_um,
        'Thickness_m': thickness_m,
        'T_hot_C': T_hot,
        'T_cold_C': T_cold,
        'P_hot_Pa': P_hot_Pa,
        'P_cold_Pa': P_cold_Pa,
        'DeltaP_Pa': delta_P_Pa,
        'J_predicted_kg_m2_h': J_predicted,
        'J_predicted_kg_m2_h_direct': J_predicted_direct
    }

