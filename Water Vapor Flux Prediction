# Extract materials with experimental data
materials_with_exp = df[df['Experimental_Flux_kg_m2_h'].notna()].copy()

if len(materials_with_exp) > 0:
    print(f"\nMaterials tested experimentally: {len(materials_with_exp)}")
    print("-" * 80)
    
    validation_table = materials_with_exp[
        ['Material', 'Predicted_Flux_kg_m2_h', 'Experimental_Flux_kg_m2_h']
    ].copy()
    
    # Calculate errors
    validation_table['Absolute_Error'] = (
        abs(validation_table['Predicted_Flux_kg_m2_h'] - 
            validation_table['Experimental_Flux_kg_m2_h'])
    )
    validation_table['Percent_Error'] = (
        (validation_table['Absolute_Error'] / 
         validation_table['Experimental_Flux_kg_m2_h']) * 100
    )
    
    # Format for display
    validation_table['Predicted_Flux_kg_m2_h'] = validation_table['Predicted_Flux_kg_m2_h'].apply(lambda x: f"{x:.2f}")
    validation_table['Experimental_Flux_kg_m2_h'] = validation_table['Experimental_Flux_kg_m2_h'].apply(lambda x: f"{x:.2f}")
    validation_table['Absolute_Error'] = validation_table['Absolute_Error'].apply(lambda x: f"{x:.2f}")
    validation_table['Percent_Error'] = validation_table['Percent_Error'].apply(lambda x: f"{x:.1f}%")
    
    print(validation_table.to_string(index=False))
    
    # Calculate statistics
    predicted = materials_with_exp['Predicted_Flux_kg_m2_h'].values
    experimental = materials_with_exp['Experimental_Flux_kg_m2_h'].values
    
    absolute_errors = np.abs(predicted - experimental)
    percent_errors = (absolute_errors / experimental) * 100
    
    # Correlation analysis
    correlation, p_value = stats.pearsonr(predicted, experimental)
    
    print(f"\n--- PREDICTION ACCURACY METRICS ---")
    print(f"Mean Absolute Error (MAE): {np.mean(absolute_errors):.2f} kg·m⁻²·h⁻¹")
    print(f"Mean Percent Error (MPE): {np.mean(percent_errors):.1f}%")
    print(f"Root Mean Square Error (RMSE): {np.sqrt(np.mean(absolute_errors**2)):.2f} kg·m⁻²·h⁻¹")
    print(f"Pearson Correlation (r): {correlation:.3f}")
    print(f"Correlation p-value: {p_value:.4f}")
    
    # Model assessment
    print(f"\n--- MODEL PERFORMANCE ASSESSMENT ---")
    if np.mean(percent_errors) < 20:
        print("✓ GOOD: Model predictions within ±20% of experimental values")
    elif np.mean(percent_errors) < 50:
        print("⚠ MODERATE: Model predictions within ±50% of experimental values")
    else:
        print("✗ LIMITED: Model predictions show significant deviation from experimental values")
    
    if correlation > 0.8 and p_value < 0.05:
        print("✓ STRONG: Significant correlation between predicted and experimental trends (p < 0.05)")
    elif correlation > 0.5 and p_value < 0.05:
        print("⚠ MODERATE: Moderate correlation, model captures relative performance trends")
    else:
        print("✗ WEAK: Weak correlation, model may not reliably rank materials")

